{
  "manifest_version": 3,
  "name": "Tabulate",
  "version": "0.1.0",
  "description": "AI-powered tab manager: cluster, summarize, and archive your open tabs.",
  "permissions": ["tabs", "storage", "scripting"],
  "host_permissions": ["http://*/*", "https://*/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Tabulate"
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "options_page": "options.html"
}
